{
  "name": "tock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup-services": "docker-compose up -d",
    "setup-db": "pnpm run -F database push-dev",
    "setup-graphql-codegen": "pnpm -F graphql-api generate-schema",
    "dev": "pnpm run setup-services && pnpm run setup-db && pnpm run setup-graphql-codegen && pnpm -r --parallel '/^dev:?.*/'",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --parallel typecheck"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
